# 네이버 검색 API (애플리케이션 등록 시 「검색」 선택)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Gemini API (SEO 페이지 자동 생성)
GEMINI_API_KEY=

# 사이트 URL (sitemap, OG 이미지 등)
SITE_URL=https://demolishzone.yourdogzone.co.kr

# Vercel 배포 시: Storage → Blob 연결 시 자동 설정 (OIDC)
# BLOB_STORE_ID=store_...
# BLOB_ACCESS=private  (기본: private → public 순으로 시도)
# 또는 구형 방식: BLOB_READ_WRITE_TOKEN=

# 선택: Cloudflare R2 (Blob 대신 사용 가능)
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# 멀티 테넌트 (Supabase + Vercel API) — 신규 서브도메인 사이트용
# Supabase → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role키
# Vercel → Account Tokens / 프로젝트 Settings → General → Project ID
VERCEL_TOKEN=
VERCEL_PROJECT_ID=prj_xxxxxxxx
# 또는 프로젝트 이름: VERCEL_PROJECT_NAME=1977demol
# 팀 계정일 때만 (개인 계정이면 비움)
# VERCEL_TEAM_ID=team_xxxxxxxx

# 선택: 레거시 단일 사이트 env 폴백
# NEXT_PUBLIC_BRAND_NAME=
# NEXT_PUBLIC_SITE_URL=
